NODE_ENV=production
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/pbp-planner
SECRET=replace-with-a-long-random-secret
REDIS_URL=redis://default:PASSWORD@HOST:6379
RUSA_CACHE_TTL_SECONDS=3600
RUSA_WARM_REGION_IDS=58
APP_BASE_URL=https://your-pbp-planner.example.com

# Optional server-level Ride with GPS credentials. The app also supports
# per-import credentials submitted by the logged-in user and does not store them.
# Server-level credential imports are disabled unless this flag is true.
RWGPS_ALLOW_SERVER_CREDENTIAL_IMPORTS=false
RWGPS_API_KEY=
RWGPS_AUTH_TOKEN=
